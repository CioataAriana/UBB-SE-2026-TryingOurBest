<UserControl x:ConnectionId='1'
    x:Class="MovieShop.Views.FlashSaleBanner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="BannerRoot">

    <Border x:ConnectionId='2' x:Name="BannerBorder" 
            Background="#D32F2F" 
            Padding="10"
                                                                 >

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
            <TextBlock Text="FLASH SALE ENDS IN:" Foreground="White" FontWeight="Bold"/>

            <TextBlock x:ConnectionId='3' x:Name="TimerText" 
                                                                        
                       Foreground="White" 
                       FontWeight="Bold"/>
        </StackPanel>
    </Border>
</UserControl>

